    dialogueStep:
      xh_isPlayer: 0
      content: "\u770B\u770B\u4F60\u90FD\u505A\u4E86\u4EC0\u4E48\u3002\n"
      actionObject: {fileID: 0}
      deactivateObject: 0
      xh_isBranchPage: 0
      xh_choices: []
    hasTriggered: 0
  - triggerHPPercent: 0.8
    dialogueStep:
      xh_isPlayer: 0
      content: "\u4F60\u7ADF\u4EE5\u4E3A\u81EA\u5DF1\u80FD\u6311\u6218\u795E\uFF0C\u628A\u6211\u4EEC\u7684\u4FE1\u4EF0\u79F0\u4E3A\u602A\u7269\u3002"
