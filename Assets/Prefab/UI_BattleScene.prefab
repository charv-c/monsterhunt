      deactivateObject: 0
      xh_isBranchPage: 0
      xh_choices: []
    hasTriggered: 0
  - triggerHPPercent: 0.7
    dialogueStep:
      xh_isPlayer: 0
      content: "\u8FD9\u4E9B\u5E74\u6765\uFF0C\u53EA\u8981\u6BCF\u4E2A\u6708\u9001\u4E0A\u4E24\u5934\u7F8A\uFF0C\u4E00\u575B\u9152\uFF0C\u795E\u5C31\u4E0D\u518D\u5403\u4EBA\uFF0C\u4FDD\u4F51\u6751\u5E84\u98CE\u8C03\u96E8\u987A\u3002"
      actionObject: {fileID: 0}
      deactivateObject: 0
