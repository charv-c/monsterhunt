  xh_combatStartDialogue:
    xh_isPlayer: 0
    content: "\u5BF9\u4F60\u8FD9\u79CD\u4E0D\u656C\u7684\u4EBA\u6765\u8BF4\uFF0C\u7528\u4EC0\u4E48\u624B\u6BB5\u90FD\u4E0D\u4E3A\u8FC7\u3002"
