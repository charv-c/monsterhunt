  - triggerHPPercent: 0.5
    dialogueStep:
      xh_isPlayer: 0
      content: "\u5982\u679C\u6CA1\u6709\u4F60\uFF0C\u6839\u672C\u4E0D\u9700\u8981\u6B7B\u90A3\u4E48\u591A\u4EBA\uFF01"
