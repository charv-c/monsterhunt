  - triggerHPPercent: 0.6
    dialogueStep:
      xh_isPlayer: 0
      content: "\u4F60\u7684\u51FA\u73B0\u6BC1\u4E86\u6211\u4EEC\u7684\u5B81\u9759\u751F\u6D3B\uFF01\u662F\u4F60\u7684\u4EB5\u6E0E\u52FE\u8D77\u795E\u660E\u7684\u6012\u706B\uFF0C\u8BA9\u6751\u5B50\u906D\u53D7\u795E\u7F5A\u3002"
